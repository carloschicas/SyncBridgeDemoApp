# ─── Application ───────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=syncbridge
POSTGRES_PASSWORD=syncbridge_secret
POSTGRES_DB=syncbridge_demo
POSTGRES_PORT=5432

# DATABASE_URL is constructed automatically by docker-compose.
# Set this manually only when running the app outside Docker:
# DATABASE_URL=postgresql://syncbridge:syncbridge_secret@localhost:5432/syncbridge_demo

# ─── Idempotency ────────────────────────────────────────────────────────────────
# How long idempotency records are kept (days). Min: 7, Max: 30.
IDEMPOTENCY_TTL_DAYS=30

# How often the TTL cleanup job runs (milliseconds). Default: 1 hour.
TTL_CLEANUP_INTERVAL_MS=3600000
